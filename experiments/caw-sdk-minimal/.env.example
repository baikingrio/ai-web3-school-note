# Copy to .env and fill with local development credentials.
# Do NOT commit .env. These values come from CAW onboarding / caw CLI.

AGENT_WALLET_API_URL=
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=

# Optional demo parameters. Keep testnet and small amounts only.
CAW_CHAIN_ID=SETH
CAW_TOKEN_ID=SETH_USDC
CAW_ALLOWED_AMOUNT=0.001
CAW_DENIED_AMOUNT=0.005
CAW_DENY_THRESHOLD=0.002
CAW_DESTINATION=0x1111111111111111111111111111111111111111
