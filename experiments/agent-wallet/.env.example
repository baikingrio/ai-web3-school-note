# Sepolia RPC (Alchemy / Infura / public)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Agent delegate EOA — testnet only, never commit real keys
AGENT_PRIVATE_KEY=0x

# Safe owner — for setModuleGuard / deploy only (optional)
OWNER_PRIVATE_KEY=0x
DEPLOYER_PRIVATE_KEY=0x

# Guard deploy: comma-separated whitelist (one address for MVP)
# GUARD_RECIPIENTS=0xYourWhitelistRecipient
# GUARD_EXPIRES_AT=1893456000

# Optional: dry-run simulates only, no broadcast
DRY_RUN=false
